# Copy this file to .env and fill in real values. .env is gitignored.
#
# EXPO_PUBLIC_* values are INLINED into the app bundle and extractable by
# anyone who downloads the app — they are NOT secret. Only put client-safe
# values here. Real secrets (service_role key, API keys) belong server-side
# (Edge Functions / EAS secrets), never in this file.

# Mock-first toggle. true = run with no backend; flip to false once Supabase is
# wired AND the two values below are filled in.
EXPO_PUBLIC_USE_MOCKS=true

# Supabase — client-safe (anon key is protected by Row Level Security).
# From your Supabase project → Settings → API. Restart Metro after changing.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
